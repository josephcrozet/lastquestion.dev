{
  "name": "lastquestion-dev",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow bun",
    "postinstall": "simple-git-hooks",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview --open",
    "start": "bun run build && bun run preview",
    "astro": "astro",
    "format": "biome check --linter-enabled=false . && prettier --check --log-level warn .",
    "format:fix": "biome format --write . && prettier --write --log-level warn .",
    "lint": "biome lint --error-on-warnings . && eslint --max-warnings 0 .",
    "lint:fix": "biome check --write --formatter-enabled=false . && eslint --fix .",
    "knip": "knip",
    "sync": "astro sync --silent",
    "check": "astro check --noSync --silent",
    "check:astro": "astro check --noSync --silent --tsconfig tsconfig.astro.json",
    "check:ts": "./node_modules/@typescript/native/bin/tsc",
    "check:ci": "bun run --parallel check:ts check:astro",
    "ci": "bun run sync && bun run --parallel format lint knip check:ci build",
    "fix": "bun run --sequential lint:fix format:fix"
  },
  "simple-git-hooks": {
    "pre-push": "bun run ci"
  },
  "knip": {
    "ignoreDependencies": [
      "@typescript/native"
    ]
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.6",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.2",
    "@typescript-eslint/parser": "^8.62.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^2.1.1",
    "knip": "^6.26.0",
    "only-allow": "^1.2.2",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=26.0.0"
  }
}
