{
  "name": "lastquestion-dev",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "knip": "knip",
    "fix": "bun run format && bun run lint:fix",
    "ci": "bun run check && bun run format:check && bun run lint && bun run knip && bun run build",
    "preinstall": "npx only-allow bun",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.3",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "@astrojs/check": "^0.9.8",
    "eslint": "^10.2.0",
    "eslint-plugin-astro": "^1.6.0",
    "knip": "^6.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2"
  },
  "simple-git-hooks": {
    "pre-push": "bun run ci"
  }
}
