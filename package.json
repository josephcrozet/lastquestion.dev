{
  "name": "lastquestion-dev",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow bun",
    "postinstall": "simple-git-hooks",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview --open",
    "start": "bun run build && bun run preview",
    "astro": "astro",
    "format": "biome check --linter-enabled=false . && prettier --check --log-level warn .",
    "format:fix": "biome format --write . && prettier --write --log-level warn .",
    "lint": "biome lint --error-on-warnings . && eslint --max-warnings 0 .",
    "lint:fix": "biome check --write --formatter-enabled=false . && eslint --fix .",
    "knip": "knip",
    "sync": "astro sync --silent",
    "check": "astro check --noSync --silent",
    "check:astro": "astro check --noSync --silent --tsconfig tsconfig.astro.json",
    "check:ts": "tsgo",
    "check:ci": "bun run --parallel check:ts check:astro",
    "ci": "bun run sync && bun run --parallel format lint knip check:ci build",
    "fix": "bun run --sequential lint:fix format:fix"
  },
  "simple-git-hooks": {
    "pre-push": "bun run ci"
  },
  "knip": {
    "ignoreDependencies": [
      "@typescript-eslint/parser"
    ]
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.2.1",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.4.14",
    "@typescript-eslint/parser": "^8.59.1",
    "@typescript/native-preview": "^7.0.0-dev.20260502.1",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.7.0",
    "knip": "^6.10.0",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "vite": "7.3.2"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
