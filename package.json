{
  "name": "lastquestion-dev",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "build": "astro build",
    "preview": "astro preview",
    "start": "bun run build && bun run preview",
    "astro": "astro",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint --max-warnings 0 . && knip",
    "lint:fix": "eslint --fix .",
    "biome": "biome check",
    "ci": "bun run format && bun run lint && bun run check && bun run build",
    "fix": "bun run format:fix && bun run lint:fix",
    "preinstall": "npx only-allow bun",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.8",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@astrojs/check": "^0.9.8",
    "@biomejs/biome": "^2.4.12",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "knip": "^6.4.1",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-push": "bun run ci"
  }
}
